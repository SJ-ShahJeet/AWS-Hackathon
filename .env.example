# Copy to .env in the repository root (single file for agent + Vite).

# --- LiveKit ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Frontend (Vite); public vars must use VITE_ prefix ---
VITE_LIVEKIT_URL=
VITE_API_BASE=

# --- Agent / app ---
ENABLE_AVATAR=false

# --- MCP (LiveKit agent uses MCP_URL; optional) ---
MCP_URL=
MCP_API_KEY=

# --- Google Workspace (Calendar + Gmail via gws CLI) ---
# One-time setup:
#   1. npm install -g @googleworkspace/cli
#   2. gws auth setup   (or manual OAuth via Google Cloud Console)
#   3. gws auth export --unmasked | base64 -w 0
#   4. Paste the output below
GOOGLE_CREDENTIALS_JSON_B64=
# Or point directly to an existing credentials file (takes priority over above):
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/path/to/credentials.json

# --- Tavus ---
TAVUS_API_KEY=
REPLICA_ID=
PERSONA_ID=

# --- ElevenLabs TTS (ELEVEN_API_KEY is an alternate name supported by the agent) ---
ELEVENLABS_API_KEY=
ELEVEN_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Hedra ---
HEDRA_API_KEY=
HEDRA_DEFAULT_AVATAR_ID=

# --- Anam ---
# ANAM_AVATAR_ID: avatar id from GET https://api.anam.ai/v1/avatars, or persona id.
ANAM_API_KEY=
ANAM_AVATAR_ID=681e6c8b-18d6-4701-b1b4-fbb2b2a8118c
# ANAM_API_URL=
