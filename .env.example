HEDRA_DEFAULT_AVATAR_ID=

MCP_URL=
MCP_API_KEY=

# ElevenLabs TTS (custom voice used by all avatar providers)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
